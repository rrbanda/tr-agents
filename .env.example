# LLM Configuration
LLAMASTACK_API_KEY=not-needed
LLM_API_BASE=https://your-llamastack-url/v1
LLM_MODEL_ID=openai/gemini/models/gemini-2.5-flash

# ServiceNow (for mock-backends proxy and MCP server)
SERVICENOW_URL=https://devXXXXXX.service-now.com
SERVICENOW_USERNAME=admin
SERVICENOW_PASSWORD=your-password
SERVICENOW_AUTH_TYPE=basic
SERVICENOW_MCP_URL=http://servicenow-mcp:8080

# SonataFlow (auto-configured in-cluster)
SONATAFLOW_NAMESPACE=sonataflow-infra
DATA_INDEX_URL=http://sonataflow-platform-data-index-service.sonataflow-infra.svc.cluster.local

# Logging
LOG_LEVEL=INFO
